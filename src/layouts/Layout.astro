---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CookieConsent from '../components/CookieConsent.astro';

const { title = "Przemek Malirz - Portfolio", description = "Modern frontend developer portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
		<title>{title}</title>
		<ClientRouter />

		{import.meta.env.PROD && (
			<>
				<!-- Google tag (gtag.js) Setup with Consent Mode -->
				<script is:inline>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}

					// Basic consent mode setup before gtag starts
					var hasConsent = localStorage.getItem('cookie-consent') === 'granted';
					gtag('consent', 'default', {
						'analytics_storage': hasConsent ? 'granted' : 'denied',
						'ad_storage': hasConsent ? 'granted' : 'denied',
						'ad_user_data': hasConsent ? 'granted' : 'denied',
						'ad_personalization': hasConsent ? 'granted' : 'denied'
					});

					gtag('js', new Date());
					gtag('config', 'G-30F0RT6G0V');
				</script>
				<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-30F0RT6G0V"></script>
			</>
		)}
	</head>
	<body>
		<main>
			<slot />
		</main>
		<CookieConsent />
	</body>
</html>

<style>
	main {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		position: relative;
		z-index: 1;
	}
</style>
