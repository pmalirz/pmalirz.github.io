---
const projects = [
  {
    title: "E-Commerce Platform",
    desc: "A modern, high-performance storefront with headless CMS integration.",
    tech: ["Next.js", "Tailwind", "Stripe"],
    link: "#"
  },
  {
    title: "Portfolio Template",
    desc: "Dynamic, 3D interactive portfolio base for creative developers.",
    tech: ["Astro", "Three.js", "Vanilla CSS"],
    link: "#"
  },
  {
    title: "Dashboard App",
    desc: "Real-time analytics dashboard with complex data visualization.",
    tech: ["React", "D3.js", "Firebase"],
    link: "#"
  }
];
---

<section id="projects" class="page-container container section-animate">
  <div class="header">
    <h2 class="page-title gradient-text">Featured Work</h2>
    <p class="page-desc">A selection of my recent projects and experiments.</p>
  </div>

  <div class="projects-grid">
    {projects.map((project, index) => (
      <a href={project.link} class="project-card glass" style={`transition-delay: ${index * 0.1}s`}>
        <div class="project-content">
          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.desc}</p>
          <div class="tech-stack">
            {project.tech.map(t => <span class="tech">{t}</span>)}
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .page-container {
    padding-top: 100px;
    padding-bottom: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1rem;
  }
  .page-desc {
    color: var(--color-text);
    font-size: 1.2rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
  }

  .project-card {
    display: block;
    height: 100%;
    padding: 2.5rem;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, opacity 0.6s ease, transform 0.6s ease;
  }

  .section-animate .header, .section-animate .project-card {
    opacity: 0;
    transform: translateY(30px);
  }

  .section-animate.visible .header, .section-animate.visible .project-card {
    opacity: 1;
    transform: translateY(0);
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(138,43,226,0.1), rgba(0,255,255,0.1));
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .project-card:hover {
    transform: translateY(-5px) !important;
    border-color: rgba(0, 255, 255, 0.4);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .project-title {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    color: var(--color-heading);
    transition: color 0.3s ease;
  }

  .project-card:hover .project-title {
    color: var(--color-secondary);
  }

  .project-desc {
    color: var(--color-text);
    margin-bottom: 2rem;
    flex-grow: 1;
    line-height: 1.6;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech {
    font-size: 0.8rem;
    color: var(--color-primary);
    background: rgba(138, 43, 226, 0.1);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
  }
</style>
