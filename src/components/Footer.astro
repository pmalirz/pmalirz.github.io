---
// components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="footer-section">
  <div class="container footer-content">
    <div class="footer-left">
      <p class="copyright">
        © {currentYear} <span class="author-name">Przemek Malirz</span>. All rights reserved.
      </p>
      <p class="built-with">
        Built with  
        <a href="https://astro.build/" target="_blank" rel="noopener" title="Astro" class="tech-link">
          <i class="devicon-astro-plain"></i>
        </a>
        <span class="separator">·</span>
        <a href="https://threejs.org/" target="_blank" rel="noopener" title="Three.js" class="tech-link">
          <i class="devicon-threejs-original"></i>
        </a>
        <span class="separator">·</span>
        <a href="https://developer.mozilla.org/en-US/docs/Web/CSS" target="_blank" rel="noopener" title="Vanilla CSS" class="tech-link">
          <i class="devicon-css3-plain"></i>
        </a>
      </p>
    </div>
    
    <div class="footer-center">
      <div class="appreciation-box">
        <span class="appreciation-text">If you like this site, click here:</span>
        <button id="like-btn" class="like-btn" aria-label="Like this site" title="Send a Like">
          <i class="fa-solid fa-heart like-icon"></i>
        </button>
      </div>
      <div id="thank-you-msg" class="thank-you-msg">Thanks for the <i class="fa-solid fa-fire"></i>!</div>
    </div>
    
    <div class="footer-right">
      <a href="https://github.com/pmalirz/" target="_blank" rel="noopener" class="footer-social"><i class="devicon-github-original"></i></a>
      <a href="https://www.linkedin.com/in/przemyslawmalirz/" target="_blank" rel="noopener" class="footer-social"><i class="devicon-linkedin-plain"></i></a>
      <a href="https://x.com/pmalirz" target="_blank" rel="noopener" class="footer-social"><i class="fa-brands fa-x-twitter"></i></a>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    width: 100%;
    padding: 2rem 0;
    margin-top: 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(15, 10, 5, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 10;
    position: relative;
  }

  .footer-content {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .copyright {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .author-name {
    color: var(--color-primary);
    font-family: var(--font-primary);
    font-weight: 500;
  }

  .built-with {
    font-size: 0.85rem;
    color: rgba(232, 220, 199, 0.7); /* Slightly dimmed text */
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .tech-link {
    font-size: 1.2rem;
    color: rgba(232, 220, 199, 0.7);
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .tech-link:hover {
    color: var(--color-secondary);
    transform: translateY(-2px);
  }

  .separator {
    opacity: 0.3;
  }

  .footer-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .appreciation-box {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .appreciation-text {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .like-btn {
    background: none;
    border: none;
    cursor: pointer;
    outline: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.2rem;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .like-icon {
    font-size: 1.4rem;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.3s ease,text-shadow 0.3s ease;
  }

  .like-btn:hover .like-icon {
    color: var(--color-accent);
    text-shadow: 0 0 10px rgba(230, 126, 34, 0.5);
  }

  .like-btn:active {
    transform: scale(0.8);
  }

  .like-btn.liked .like-icon {
    color: #e74c3c;
    text-shadow: 0 0 15px rgba(231, 76, 60, 0.6);
    animation: heartbeat 1s cubic-bezier(0.25, 1, 0.5, 1);
  }


  .thank-you-msg {
    font-size: 0.85rem;
    color: var(--color-patina);
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s ease;
    height: 0;
    overflow: visible;
    position: absolute;
    bottom: -20px;
  }

  .thank-you-msg.show {
    opacity: 1;
    transform: translateY(0);
  }

  .footer-right {
    display: flex;
    gap: 1.2rem;
  }

  .footer-social {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.5);
    transition: all 0.3s ease;
  }

  .footer-social:hover {
    color: var(--color-primary);
    transform: translateY(-3px);
  }

  @keyframes heartbeat {
    0% { transform: scale(1); }
    15% { transform: scale(1.3); }
    30% { transform: scale(1); }
    45% { transform: scale(1.3); }
    60% { transform: scale(1); }
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .built-with {
      justify-content: center;
    }
  }
</style>

<script>
  // Script for the like functionality and Google Analytics Event
  const setupLikeButton = () => {
    const likeBtn = document.getElementById('like-btn');
    const thankYouMsg = document.getElementById('thank-you-msg');
    
    if (!likeBtn) return;

    likeBtn.addEventListener('click', function handleLike() {
      // Small visual feedback
      likeBtn.classList.remove('liked');
      void likeBtn.offsetWidth; // trigger reflow
      likeBtn.classList.add('liked');

      // Show thank you message temporarily
      if (thankYouMsg) {
        thankYouMsg.classList.add('show');
        setTimeout(() => {
          thankYouMsg.classList.remove('show');
        }, 3000);
      }

      // 🔴 Send the interaction to Google Analytics
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'design_appreciation', {
          'event_category': 'engagement',
          'event_label': 'footer_like_button',
          'value': 1
        });
      }
    });
  };

  // Run on initial load
  setupLikeButton();

  // Run after view transitions
  document.addEventListener('astro:page-load', setupLikeButton);
</script>
