<div class="hero-container">
  <canvas id="hero-canvas"></canvas>
  <div class="content">
    <h1 class="title">Architecting <br/><span class="gradient-text">Optimal Solutions</span></h1>
    <p class="subtitle">Where cutting-edge technology seamlessly meets business vision.</p>
    <div class="cta-group">
      <a href="#projects" class="btn glass">View My Work</a>
      <a href="#contact" class="btn-outline">Say Hello</a>
    </div>
  </div>
  <a href="#about" class="scroll-indicator" aria-label="Scroll to About Section">
    <span>Scroll</span>
    <div class="mouse">
      <div class="wheel"></div>
    </div>
  </a>
</div>

<style>
  .hero-container {
    position: relative;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #hero-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }
  .content {
    text-align: center;
    z-index: 10;
    pointer-events: none;
    padding: 0 1rem;
  }
  .title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-bottom: 1rem;
    animation: fadeInUp 1s ease-out forwards;
    opacity: 0;
  }
  .subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    color: var(--color-text);
    margin-bottom: 2.5rem;
    animation: fadeInUp 1s ease-out 0.3s forwards;
    opacity: 0;
  }
  .cta-group {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    pointer-events: auto;
    animation: fadeInUp 1s ease-out 0.6s forwards;
    opacity: 0;
  }
  .btn, .btn-outline {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: var(--transition);
  }
  .btn {
    
  }
  .btn:hover {
    background: var(--color-surface-hover);
    transform: translateY(-3px);
    box-shadow: 0 10px 40px rgba(138, 43, 226, 0.3);
  }
  .btn-outline {
    border: 1px solid var(--color-secondary);
    color: var(--color-secondary);
  }
  .btn-outline:hover {
    background: rgba(0, 255, 255, 0.1);
    transform: translateY(-3px);
    box-shadow: 0 10px 40px rgba(0, 255, 255, 0.2);
  }
  
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0;
    animation: fadeInUp 1s ease-out 1s forwards;
  }
  .mouse {
    width: 26px;
    height: 40px;
    border: 2px solid var(--color-text);
    border-radius: 15px;
    position: relative;
  }
  .wheel {
    width: 4px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 2px;
    position: absolute;
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
    animation: scroll 1.5s infinite;
  }
  @keyframes scroll {
    0% { transform: translate(-50%, 0); opacity: 1; }
    100% { transform: translate(-50%, 15px); opacity: 0; }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  import * as THREE from 'three';

  function initThreeJS() {
    const canvas = document.querySelector('#hero-canvas');
    if (!canvas) return;

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x0a0a0a, 0.05);

    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 3, 10);
    camera.lookAt(0, -2, 0);

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, powerPreference: "high-performance" });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);

    // --- OCEAN GRID ---
    const isMobile = window.innerWidth < 768;
    const countX = isMobile ? 120 : 250;
    const countZ = isMobile ? 120 : 200;
    const gap = isMobile ? 0.25 : 0.15;
    const numParticles = countX * countZ;

    const particlesGeometry = new THREE.BufferGeometry();
    const posArray = new Float32Array(numParticles * 3);
    const colorsArray = new Float32Array(numParticles * 3);
    const originalPositions = new Float32Array(numParticles * 3);
    const originalColors = new Float32Array(numParticles * 3);
    
    const colorPrimary = new THREE.Color(0x8a2be2);
    const colorSecondary = new THREE.Color(0x00ffff);

    let index = 0;
    for (let i = 0; i < countX; i++) {
      for (let j = 0; j < countZ; j++) {
        const x = (i - countX / 2) * gap;
        const z = (j - countZ / 2) * gap;
        const y = 0;

        posArray[index * 3] = x;
        posArray[index * 3 + 1] = y;
        posArray[index * 3 + 2] = z;

        originalPositions[index * 3] = x;
        originalPositions[index * 3 + 1] = y;
        originalPositions[index * 3 + 2] = z;

        const mixRatio = (Math.sin(i * 0.05) + Math.cos(j * 0.05) + 2) / 4;
        const mixedColor = colorPrimary.clone().lerp(colorSecondary, mixRatio);
        
        colorsArray[index * 3] = mixedColor.r;
        colorsArray[index * 3 + 1] = mixedColor.g;
        colorsArray[index * 3 + 2] = mixedColor.b;

        originalColors[index * 3] = mixedColor.r;
        originalColors[index * 3 + 1] = mixedColor.g;
        originalColors[index * 3 + 2] = mixedColor.b;
        
        index++;
      }
    }

    particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    particlesGeometry.setAttribute('color', new THREE.BufferAttribute(colorsArray, 3));

    const particlesMaterial = new THREE.PointsMaterial({
      size: isMobile ? 0.06 : 0.04,
      vertexColors: true,
      blending: THREE.AdditiveBlending,
      transparent: true,
      opacity: 0.9,
      depthWrite: false
    });

    const particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
    particlesMesh.position.y = -3;
    scene.add(particlesMesh);

    // --- INTERACTION PLANE ---
    const raycaster = new THREE.Raycaster();
    const mouseParams = new THREE.Vector2(-9999, -9999);
    const invisiblePlane = new THREE.Mesh(
      new THREE.PlaneGeometry(200, 200),
      new THREE.MeshBasicMaterial({ visible: false })
    );
    invisiblePlane.rotation.x = -Math.PI / 2;
    invisiblePlane.position.y = -3;
    scene.add(invisiblePlane);

    const handleMouseMove = (event) => {
      mouseParams.x = (event.clientX / window.innerWidth) * 2 - 1;
      mouseParams.y = -(event.clientY / window.innerHeight) * 2 + 1;
    };
    document.addEventListener('mousemove', handleMouseMove);

    const clock = new THREE.Clock();
    let animationFrameId;

    const animate = () => {
      animationFrameId = requestAnimationFrame(animate);
      const elapsedTime = clock.getElapsedTime();

      // Find mouse intersection in 3D
      raycaster.setFromCamera(mouseParams, camera);
      const intersects = raycaster.intersectObject(invisiblePlane);
      let hoverPoint = null;
      if (intersects.length > 0) {
        hoverPoint = intersects[0].point;
      }

      const positions = particlesGeometry.attributes.position;
      const posArr = positions.array;
      const colors = particlesGeometry.attributes.color;
      const colArr = colors.array;

      for (let i = 0; i < numParticles; i++) {
        const i3 = i * 3;
        
        const origX = originalPositions[i3];
        const origZ = originalPositions[i3 + 2];
        const origY = originalPositions[i3 + 1];

        // Gentle ocean waves
        let targetY = origY + Math.sin(elapsedTime * 1.5 + origX * 0.8) * 0.4 + Math.cos(elapsedTime * 1.5 + origZ * 0.8) * 0.4;
        let targetX = origX;
        let targetZ = origZ;

        // Hover disturbance (weaving effect)
        let distanceToHover = -1;
        if (hoverPoint) {
          const localHoverX = hoverPoint.x - particlesMesh.position.x;
          const localHoverZ = hoverPoint.z - particlesMesh.position.z;

          const dx = origX - localHoverX;
          const dz = origZ - localHoverZ;
          distanceToHover = Math.sqrt(dx * dx + dz * dz);
          
          const interactionRadius = 3.5;
          if (distanceToHover < interactionRadius) {
            const force = (interactionRadius - distanceToHover) / interactionRadius;
            
            // Raise particles up like a magnetic pull
            targetY += force * 2.5; 
            
            // Swirl / weave them centrifugally based on distance
            const angle = Math.atan2(dz, dx) + (elapsedTime * 2);
            targetX += Math.cos(angle) * force * 1.2;
            targetZ += Math.sin(angle) * force * 1.2;
          }
        }

        // Smooth physics interpolation (easing back into place)
        posArr[i3] += (targetX - posArr[i3]) * 0.08;
        posArr[i3 + 1] += (targetY - posArr[i3 + 1]) * 0.08;
        posArr[i3 + 2] += (targetZ - posArr[i3 + 2]) * 0.08;
        
        // --- Light Reflexes ---
        let reflexVal = 0;
        
        // 1. Sweeping specular light band across the grid
        const lightAngle = elapsedTime * 0.4;
        const linePos = origX * Math.cos(lightAngle) + origZ * Math.sin(lightAngle);
        const sweepPos = Math.sin(elapsedTime * 0.6) * 15;
        const sweepDist = Math.abs(linePos - sweepPos);
        
        if (sweepDist < 1.5) {
          // Sharp intense bright line passing through, with strong blinking
          const blink = Math.sin(elapsedTime * 25.0 + i) * 0.5 + 0.5;
          reflexVal += Math.pow(1.0 - (sweepDist / 1.5), 2.0) * (1.2 + blink * 1.5);
        }
        
        // 2. Wave crest highlights (peaks catch the light)
        const crestHeight = targetY - origY;
        if (crestHeight > 0.3) {
           const blink = Math.sin(elapsedTime * 15.0 + i * 2) * 0.5 + 0.5;
           reflexVal += (crestHeight - 0.3) * (1.5 + blink * 2.0);
        }
        
        // 3. Hover illumination
        if (distanceToHover !== -1 && distanceToHover < 3.5) {
           const blink = Math.random() > 0.3 ? 1.5 : 0.5; // strong flicker near hover
           reflexVal += Math.pow(1.0 - (distanceToHover / 3.5), 2.0) * (1.2 * blink);
        }

        // Apply additive light to the original color
        // Making it orange tinted: high Red, medium Green, low Blue
        colArr[i3] = Math.min(1.0, originalColors[i3] + reflexVal * 1.0);       // Red
        colArr[i3 + 1] = Math.min(1.0, originalColors[i3 + 1] + reflexVal * 0.55); // Green
        colArr[i3 + 2] = Math.min(1.0, originalColors[i3 + 2] + reflexVal * 0.1);  // Blue
      }

      positions.needsUpdate = true;
      colors.needsUpdate = true;

      // Subtle camera pan linked to mouse
      camera.position.x += (mouseParams.x * 2 - camera.position.x) * 0.02;
      camera.lookAt(0, -1, 0);

      renderer.render(scene, camera);
    };

    animate();

    const handleResize = () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    };
    
    window.addEventListener('resize', handleResize);
    
    // Cleanup
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationFrameId);
      document.removeEventListener('mousemove', handleMouseMove);
      window.removeEventListener('resize', handleResize);
      renderer.dispose();
      particlesGeometry.dispose();
      particlesMaterial.dispose();
      invisiblePlane.geometry.dispose();
      invisiblePlane.material.dispose();
    }, { once: true });
  }

  // Initial load
  initThreeJS();
  
  // Re-init on navigation
  document.addEventListener('astro:page-load', () => {
    if(document.querySelector('#hero-canvas') && !document.querySelector('#hero-canvas').dataset.initialized) {
      document.querySelector('#hero-canvas').dataset.initialized = 'true';
      initThreeJS();
    }
  });
</script>
