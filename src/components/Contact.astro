<section id="contact" class="page-container container section-animate">
  <div class="header">
    <h2 class="page-title gradient-text">Get In Touch</h2>
    <p class="page-desc">I'm currently available for freelance work. Let's create something great together.</p>
  </div>

  <div class="contact-card glass">
    <form class="contact-form" onsubmit="event.preventDefault(); alert('This is a demo setup!');">
      <div class="input-group">
        <label for="name">Name</label>
        <input type="text" id="name" required placeholder="John Doe" />
      </div>
      <div class="input-group">
        <label for="email">Email</label>
        <input type="email" id="email" required placeholder="hello@example.com" />
      </div>
      <div class="input-group">
        <label for="message">Message</label>
        <textarea id="message" rows="5" required placeholder="Tell me about your project..."></textarea>
      </div>
      <button type="submit" class="submit-btn">Send Message</button>
    </form>
    <div class="socials">
      <h3 class="socials-title">Or find me on</h3>
      <div class="social-links">
        <a href="mailto:p.malirz@gmail.com" class="social-link"><i class="fa-solid fa-envelope"></i> p.malirz@gmail.com</a>
        <a href="tel:+48608411472" class="social-link"><i class="fa-solid fa-phone"></i> +48 608411472</a>
        <a href="https://github.com/pmalirz/" class="social-link" target="_blank" rel="noopener"><i class="devicon-github-original"></i> GitHub</a>
        <a href="https://www.linkedin.com/in/przemyslawmalirz/" class="social-link" target="_blank" rel="noopener"><i class="devicon-linkedin-plain"></i> LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<style>
  .page-container {
    padding-top: 100px;
    padding-bottom: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1rem;
  }
  .page-desc {
    color: var(--color-text);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-card {
    width: 100%;
    max-width: 800px;
    padding: 3rem;
    border-radius: 20px;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .section-animate .header, .section-animate .contact-card {
    opacity: 0;
    transform: translateY(30px);
  }

  .section-animate.visible .header, .section-animate.visible .contact-card {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .contact-card {
      grid-template-columns: 1fr;
      padding: 2rem;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-family: var(--font-primary);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-heading);
    letter-spacing: 0.5px;
  }

  input, textarea {
    width: 100%;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: var(--color-text);
    font-family: var(--font-secondary);
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.08);
  }

  input::placeholder, textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .submit-btn {
    margin-top: 1rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent), var(--color-patina));
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: var(--font-primary);
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
  }

  .socials {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-left: 2rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 768px) {
    .socials {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 2rem;
    }
  }

  .socials-title {
    font-size: 1.2rem;
    color: var(--color-heading);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .social-link {
    font-weight: 500;
    position: relative;
    width: fit-content;
  }

  .social-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-secondary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .social-link i {
    margin-right: 0.5rem;
    font-size: 1.1rem;
    color: var(--color-secondary);
  }

  .social-link:hover {
    color: #fff;
  }

  .social-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>
