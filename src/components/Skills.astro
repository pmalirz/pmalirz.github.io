---
const skills = [
  { category: "Core Technologies", items: ["<i class='devicon-java-plain'></i> Java", "<i class='devicon-dot-net-plain'></i> .NET / C#", "<i class='devicon-apachekafka-original'></i> Kafka", "<i class='devicon-spring-original'></i> Spring Boot", "<i class='devicon-amazonwebservices-plain-wordmark'></i> AWS"] },
  { category: "Architecture & Strategy", items: ["Enterprise Architecture", "Domain-Driven Design", "System Design", "Cloud Native"] },
  { category: "Leadership & Delivery", items: ["Technical Leadership", "Client Relations", "Cross-functional Teams", "Agile Methods"] },
  { category: "Engineering Practices", items: ["Clean Code", "CQRS / Event Sourcing", "DevOps & CI/CD", "Software Craftsmanship"] },
  { category: "Emerging Tech", items: ["<i class='fa-solid fa-robot'></i> AI Engineering", "<i class='fa-solid fa-microchip'></i> Agentic Workflows", "<i class='fa-solid fa-brain'></i> LLMs Integration", "<i class='fa-solid fa-flask'></i> R&D"] }
];
---

<section id="skills" class="page-container container section-animate">
  <div class="header">
    <h2 class="page-title gradient-text">My Arsenal & Offer</h2>
    <p class="page-desc">The strategic capabilities, leadership, and technical expertise I bring to the table.</p>
  </div>

  <div class="skills-grid">
    {skills.map((skillGroup, index) => (
      <div class="skill-card glass" style={`transition-delay: ${index * 0.1}s`}>
        <h3 class="category-title">{skillGroup.category}</h3>
        <div class="tags">
          {skillGroup.items.map((item) => (
            <span class="tag" set:html={item}></span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .page-container {
    padding-top: 100px;
    padding-bottom: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1rem;
  }
  .page-desc {
    color: var(--color-text);
    font-size: 1.2rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    width: 100%;
    max-width: 1000px;
  }
  
  .skill-card {
    padding: 2rem;
    border-radius: 20px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, opacity 0.6s ease, transform 0.6s ease;
  }

  .section-animate .header, .section-animate .skill-card {
    opacity: 0;
    transform: translateY(30px);
  }

  .section-animate.visible .header, .section-animate.visible .skill-card {
    opacity: 1;
    transform: translateY(0);
  }
  
  .skill-card:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 15px 40px rgba(138, 43, 226, 0.15);
    border-color: rgba(138, 43, 226, 0.3);
  }

  .category-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-heading);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .tag {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.9rem;
    color: var(--color-text);
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* Target dynamically inserted icons within the tag */
  :global(.tag i) {
    font-size: 1.1rem;
    color: var(--color-secondary);
    transition: color 0.3s ease;
  }

  .tag:hover :global(i) {
    color: #fff;
  }

  .tag:hover {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
    transform: scale(1.05);
  }
</style>

<script>
  const observerCallback = (entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  };

  const setupObserver = () => {
    const sections = document.querySelectorAll('.section-animate');
    sections.forEach(sec => {
      const observer = new IntersectionObserver(observerCallback, {
        threshold: 0.1
      });
      observer.observe(sec);
    });
  };

  setupObserver();
  document.addEventListener('astro:page-load', setupObserver);
</script>
