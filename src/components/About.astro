---
// components/About.astro
---

<section id="about" class="about-section container">
  <div class="glass about-card">
    <div class="content-wrapper">
      <div class="text-content">
        <h2 class="section-title gradient-text">About Me</h2>
        
        <p class="bio highlight">
          I am a <strong>Solution and Enterprise Architect</strong> passionate about bridging the gap between ambitious business visions and flawless technical execution.
        </p>

        <p class="bio">
          For me, technology is a serious commitment. I take ownership of the entire software lifecycle, steering projects from concept to production while ensuring they are uncompromisingly secure and compliant by design. Whether navigating NIST, DORA, or the AI Act, I architect scalable systems that are both regulatory-proof and engineered to the highest standards, particularly within the core business domain.
        </p>

        <p class="bio">
          My philosophy is rooted in <strong>pragmatism</strong>. I do not build complexity for the sake of it; instead, I champion the use of existing infrastructure and proven patterns to solve genuine problems. I firmly believe that a truly successful system must be easy to manage, maintain, and—crucially—<strong>easy to develop</strong>. By prioritizing frictionless developer environments and comprehensive observability, I ensure teams have the deep, actionable insights needed to continuously optimize performance and swiftly resolve production issues.
        </p>

        <p class="bio">
          Quality is non-negotiable. I look beyond superficial metrics like simple code coverage, focusing instead on the actual integrity of testing and strict adherence to foundational principles such as SOLID, the Law of Demeter, and the 12-Factor App methodology. While I am confident in driving any technical initiative to the finish line, experience has taught me that the most overwhelming engineering challenges usually stem from a misunderstanding of the business itself. Therefore, deep alignment with business goals remains the bedrock of my work.
        </p>
        
        <p class="bio">
          Having led decentralized, agile engineering teams across diverse environments, I excel at translating ambiguous requirements into precise technical strategies. <strong>I tailor the technology to the problem, never the other way around.</strong> In large corporate landscapes, I actively champion <a href="https://innersourcecommons.org/" target="_blank" rel="noopener" style="color: var(--color-secondary); font-weight: 600; text-decoration: underline; text-decoration-color: rgba(184, 115, 51, 0.4); text-underline-offset: 4px;">InnerSource</a> practices to break down silos, unify standards, and foster a culture of organic, cross-team cooperation.
        </p>

        <p class="bio">
          Ultimately, my goal is to leave a lasting foundation. When I deliver a project, I provide more than just a robust technical implementation; I guarantee a complete transfer of knowledge through meticulous, multi-level documentation. I build to empower organizations—ensuring they not only utilize the systems I design but can confidently own, scale, and evolve them independently long into the future.
        </p>

        <div class="open-network-box">
          <i class="fa-solid fa-handshake handshake-icon"></i>
          <div>
            <span class="box-title">Always Open & Approachable</span>
            <p class="box-text">I genuinely enjoy expanding my network and discovering new perspectives. Whether you are a recruiter looking for a serious architectural mind, a potential partner, or a fellow tech enthusiast wanting to talk shop—don't hesitate to reach out. Follow my social links at the top and simply say hi!</p>
          </div>
        </div>
      </div>

      <div class="badges-wrapper">
        <div class="badge-group">
          <span class="badge">Architecture & Coding</span>
          <span class="badge">Enterprise & Full-Stack</span>
          <span class="badge">Tech Leader</span>
          <span class="badge">Cracow, Poland</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 2rem;
    position: relative;
    z-index: 2;
  }

  .about-card {
    padding: 3rem;
    border-radius: 24px;
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 2rem;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .bio {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .bio.highlight {
    font-size: 1.4rem;
    color: var(--color-heading);
    font-weight: 500;
  }

  .bio strong {
    color: var(--color-secondary);
    font-weight: 600;
  }


  .quote {
    margin: 2rem 0;
    padding: 1.5rem;
    border-left: 4px solid var(--color-primary);
    background: rgba(212, 175, 55, 0.05);
    border-radius: 0 12px 12px 0;
    font-style: italic;
    font-size: 1.1rem;
    color: rgba(224, 224, 224, 0.9);
  }

  .quote .author {
    display: block;
    margin-top: 0.8rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-secondary);
  }

  .badges-wrapper {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .badge-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .badge {
    background: rgba(184, 115, 51, 0.1);
    border: 1px solid rgba(184, 115, 51, 0.2);
    color: var(--color-secondary);
    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .open-network-box {
    margin-top: 2rem;
    padding: 1.5rem 2rem;
    border-radius: 16px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(85, 158, 131, 0.08);
    border-left: 4px solid var(--color-patina);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .open-network-box:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(85, 158, 131, 0.15);
  }

  .handshake-icon {
    font-size: 2.5rem;
    color: var(--color-patina);
    flex-shrink: 0;
  }

  .box-title {
    display: block;
    font-family: var(--font-primary);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 0.5rem;
  }

  .box-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .about-card {
      padding: 2rem;
    }
    .badge {
      font-size: 0.8rem;
    }
    .open-network-box {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
      border-left: none;
      border-top: 4px solid var(--color-patina);
    }
  }
</style>

<script>
  // Simple intersection observer to fade in the about section
  const observerCallback = (entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  };

  const setupObserver = () => {
    const aboutCard = document.querySelector('.about-card');
    if (aboutCard) {
      const observer = new IntersectionObserver(observerCallback, {
        threshold: 0.2
      });
      observer.observe(aboutCard);
    }
  };

  // Run on first load
  setupObserver();

  // Run on view transitions
  document.addEventListener('astro:page-load', setupObserver);
</script>
