---
// components/About.astro
---

<section id="about" class="about-section container">
  <div class="glass about-card">
    <div class="content-wrapper">
      <div class="text-content">
        <h2 class="section-title gradient-text">About Me</h2>
        
        <p class="bio highlight">
          I am a <strong>Solution and Enterprise Architect</strong>, Tech Leader, and hands-on engineer dedicated to driving business value through robust technology.
        </p>

        <p class="bio">
          With over two decades of experience, I specialize in bridging the gap between complex technical landscapes and strategic business objectives. My expertise spans the entire software lifecycle—from high-level enterprise architecture and system design to low-level, hands-on implementation. I pride myself on delivering complete, reliable, and easy-to-maintain solutions that empower teams and elevate organizations.
        </p>
        
        <p class="bio">
          Whether I am leading cross-functional teams, implementing pragmatic architectures like DDD and CQRS, or fostering strong client relations, my goal is always to align technology with business vision. Currently, I am exploring how <strong>AI and Agentic Workflows</strong> can revolutionize software delivery, and I am always open to connecting with forward-thinking companies and professionals expanding their network.
        </p>

        <p class="bio cta-text">
          If you would like to build something new, refactor something old, or consult possibilities—now is the time to <a href="#contact" class="animated-link">contact me</a>.
        </p>

        <blockquote class="quote">
          "Any intelligent fool can make things bigger, more complex, and more violent. It takes a touch of genius - and a lot of courage to move in the opposite direction." <br>
          <span class="author">— E.F. Schumacher</span>
        </blockquote>
      </div>

      <div class="badges-wrapper">
        <div class="badge-group">
          <span class="badge">Architecture & Coding</span>
          <span class="badge">Enterprise & Full-Stack</span>
          <span class="badge">Tech Leader</span>
          <span class="badge">Cracow, Poland</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 2rem;
    position: relative;
    z-index: 2;
  }

  .about-card {
    padding: 3rem;
    border-radius: 24px;
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 2rem;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .bio {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .bio.highlight {
    font-size: 1.4rem;
    color: var(--color-heading);
    font-weight: 500;
  }

  .bio strong {
    color: var(--color-secondary);
    font-weight: 600;
  }

  .cta-text {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-heading);
    margin-top: 1rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: rgba(0, 255, 255, 0.05);
    border-radius: 8px;
    border-left: 3px solid var(--color-secondary);
  }

  .animated-link {
    color: var(--color-primary);
    position: relative;
    text-decoration: none;
    font-weight: 700;
    display: inline-block;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .animated-link::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 2px;
    bottom: -2px;
    left: 0;
    background-color: var(--color-secondary);
    transform-origin: bottom right;
    transition: transform 0.3s ease-out;
  }

  .animated-link:hover {
    color: var(--color-secondary);
    transform: translateY(-2px);
  }

  .animated-link:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .quote {
    margin: 2rem 0;
    padding: 1.5rem;
    border-left: 4px solid var(--color-primary);
    background: rgba(138, 43, 226, 0.05);
    border-radius: 0 12px 12px 0;
    font-style: italic;
    font-size: 1.1rem;
    color: rgba(224, 224, 224, 0.9);
  }

  .quote .author {
    display: block;
    margin-top: 0.8rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-secondary);
  }

  .badges-wrapper {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .badge-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .badge {
    background: rgba(0, 255, 255, 0.1);
    border: 1px solid rgba(0, 255, 255, 0.2);
    color: var(--color-secondary);
    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  @media (max-width: 768px) {
    .about-card {
      padding: 2rem;
    }
    .badge {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  // Simple intersection observer to fade in the about section
  const observerCallback = (entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  };

  const setupObserver = () => {
    const aboutCard = document.querySelector('.about-card');
    if (aboutCard) {
      const observer = new IntersectionObserver(observerCallback, {
        threshold: 0.2
      });
      observer.observe(aboutCard);
    }
  };

  // Run on first load
  setupObserver();

  // Run on view transitions
  document.addEventListener('astro:page-load', setupObserver);
</script>
