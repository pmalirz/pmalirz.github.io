---
import Layout from '../layouts/Layout.astro';
import Welcome from '../components/Welcome.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Przemek Malirz | Solution & Enterprise Architecture";
const pageDescription = "Przemek Malirz - Seasoned Hands-on Enterprise & Full-Stack Architect with 20 years of experience. Specializing in AI, Distributed Systems, Microservices, Java, Kotlin, and JavaScript/TypeScript ecosystems. I bridge the gap between high-level strategy and technical execution.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Przemek Malirz",
  "jobTitle": "Principal Architect, Solution & Enterprise Architecture",
  "url": "https://pmalirz.github.io/",
  "sameAs": [
    "https://www.linkedin.com/in/przemyslawmalirz/",
    "https://github.com/pmalirz/",
    "https://x.com/pmalirz"
  ],
  "knowsAbout": [
    "Enterprise Architecture", "Artificial Intelligence", "Agentic Development", "Distributed Systems",
    "Microservices", "Microfrontends", "CQRS", "Hexagon Architecture", "DDD", "Cloud Native",
    "Java", "Kotlin", "JavaScript", "TypeScript", "React", "Next.js", "Nest.js", "Angular",
    "Spring Ecosystem", "OpenShift", "Docker", "DevOps", "CI/CD",
    "Agile", "Scrum", "Kanban", "Technical Leadership", "Event Storming", "Event Sourcing",
    "OAuth2", "Clean Code", "Secure Code"
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
	<script type="application/ld+json" set:html={JSON.stringify(schema)} />
	<Welcome />
	<About />
	<Skills />
	<Footer />
</Layout>
